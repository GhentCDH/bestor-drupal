{#
/**
 * @file
 * Theme override to display a node.
 *
 * Available variables:
 * - node: The node entity with limited access to object properties and methods.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - node.getCreatedTime() will return the node creation timestamp.
 *   - node.hasField('field_example') returns TRUE if the node bundle includes
 *     field_example. (This does not indicate the presence of a value in this
 *     field.)
 *   - node.isPublished() will return whether the node is published or not.
 *   Calling other methods, such as node.delete(), will result in an exception.
 *   See \Drupal\node\Entity\Node for a full list of public properties and
 *   methods for the node object.
 * - label: The title of the node.
 * - content: All node items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - author_picture: The node author user entity, rendered using the "compact"
 *   view mode.
 * - metadata: Metadata for this node.
 * - date: Themed creation date field.
 * - author_name: Themed author name field.
 * - url: Direct URL of the current node.
 * - display_submitted: Whether submission information should be displayed.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - node: The current template type (also known as a "theming hook").
 *   - node--type-[type]: The current node type. For example, if the node is an
 *     "Article" it would result in "node--type-article". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - node--view-mode-[view_mode]: The View Mode of the node; for example, a
 *     teaser would result in: "node--view-mode-teaser", and
 *     full: "node--view-mode-full".
 *   The following are controlled through the node publishing options.
 *   - node--promoted: Appears on nodes promoted to the front page.
 *   - node--sticky: Appears on nodes ordered above other non-sticky nodes in
 *     teaser listings.
 *   - node--unpublished: Appears on unpublished nodes visible only to site
 *     admins.
 * - title_attributes: Same as attributes, except applied to the main title
 *   tag that appears in the template.
 * - content_attributes: Same as attributes, except applied to the main
 *   content tag that appears in the template.
 * - author_attributes: Same as attributes, except applied to the author of
 *   the node tag that appears in the template.
 * - title_prefix: Additional output populated by modules, intended to be
 *   displayed in front of the main title tag that appears in the template.
 * - title_suffix: Additional output populated by modules, intended to be
 *   displayed after the main title tag that appears in the template.
 * - view_mode: View mode; for example, "teaser" or "full".
 * - teaser: Flag for the teaser state. Will be true if view_mode is 'teaser'.
 * - page: Flag for the full page state. Will be true if view_mode is 'full'.
 * - readmore: Flag for more state. Will be true if the teaser content of the
 *   node cannot hold the main body content.
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_node()
 */
#}

{# c-structured-layout.story.twig #}

{#
  Bundle config: per related bundle, label + route naar de zoekpagina.
  Routes komen uit de view 'database_advanced_search' (views.view.database_advanced_search).
  De filter URL wordt automatisch opgebouwd als:
  [route]?rel_[node.bundle()][node.bundle()][value]=node/[node.id()]
#}
{% set limit = 10 %}
{% set bundles = {
  'story':       { label: 'Related stories'|t,       more_route: 'view.database_advanced_search.page_1' },
  'concept':     { label: 'Related concepts'|t,       more_route: 'view.database_advanced_search.page_2' },
  'document':    { label: 'Related documents'|t,      more_route: 'view.database_advanced_search.page_3' },
  'institution': { label: 'Related institutions'|t,   more_route: 'view.database_advanced_search.page_4' },
  'instrument':  { label: 'Related instruments'|t,    more_route: 'view.database_advanced_search.page_5' },
  'person':      { label: 'Related persons'|t,        more_route: 'view.database_advanced_search.page_6' },
  'place':       { label: 'Related places'|t,         more_route: 'view.database_advanced_search.page_7' },
} %}
{% set bundle_order = bundles|keys %}

{# Filter key gebaseerd op de bundle van de huidige node.
   Patroon: rel_[bundle][bundle][value]=node/[nid]
   Voorbeeld: rel_institution[institution][value]=node/37 #}
{% set filter_key = 'rel_' ~ node.bundle() ~ '[' ~ node.bundle() ~ '][value]' %}
{% set filter_value = 'node/' ~ node.id() %}

{% set toc = content.toc_js %}

{% set top %}
  {% set all_media = bestor('media_info', node, 'field_image', {'image_style': 'id_kit'}) %}
  {% set image_info = all_media|length > 0 ? all_media|first : null %}
  {% if image_info %}
    {% set media %}
      {% if image_info and image_info.type == 'image' %}
        <img loading="lazy" src="{{ image_info.url }}" width="450" height="354" alt="{{ image_info.alt }}">
      {% endif %}
    {% endset %}
  {% endif %}

  {% set identity_kit_list %}
    {% for key_element in bestor('lemma_key_data', node, 'full', 'database', 'page_1') %}
      {{ include('jakarta:c-identity-kit-item', {
        title: key_element.label,
        values: key_element.value,
      }, with_context = false) }}
    {% endfor %}
  {% endset %}

  {{ include('jakarta:c-identity-kit', {
    tag: node.type.entity.label,
    media,
    identity_kit_list,
    attr_variant: 'default',
  }, with_context = false) }}
{% endset %}

{% set content %}
  {{ include('jakarta:c-meta', {
    date: node.changed.value|date('d/m/Y'),
    read_time: bestor('reading_time', node),
  }, with_context = false) }}

  {% set suggestions = bestor('translation_suggestions', node) %}
  {% if suggestions %}
    <div class="translation-suggestion">
      {{ 'We have a more extensive version of this lemma in another language:'|t }}
      {% for langcode, alt in suggestions.alternatives %}
        {% if not loop.first %} {{ 'or'|t }} {% endif %}
        <a href="{{ alt.url }}" hreflang="{{ langcode }}">{{ alt.title }}</a>
        <span>({{ alt.language_name }})</span>
      {% endfor %}
    </div>
  {% endif %}

  {% if content.field_description %}
    {{ content.field_description }}
  {% endif %}

  {% if content.body %}
    {{ content.body }}
  {% endif %}

  {% if content.field_geolocation %}
    {{ content.field_geolocation }}
  {% endif %}

  {% if content.show_ego_network %}
    {{ content.show_ego_network }}
  {% endif %}
{% endset %}

{% set sidebar %}
  {% set contact_url = bestor('translated_url', 'contact') %}
  {% set citation_text = bestor('citation') %}

  {% set buttons %}
    {% if contact_url %}
      {{ include('jakarta:c-button', {
        html_tag: 'a',
        attr_variant: 'default',
        color: 'primary',
        title: 'Suggestion'|t,
        url: contact_url
      }, with_context = false) }}
    {% endif %}
    {% if citation_text %}
      {{ include('jakarta:c-button', {
        html_tag: 'a',
        attr_variant: 'default',
        color: 'primary',
        title: 'Quote'|t,
        url: '#citation',
        c_button_utility_classes: ['js-citation-toggle']
      }, with_context = false) }}
      <div id="citation-popup" class="citation-popup" hidden>
        <button class="citation-popup-close js-citation-close" aria-label="{{ 'Close'|t }}">&times;</button>
        <h3 class="citation-popup-title">{{ 'How to cite'|t }}</h3>
        <p class="citation-popup-text">{{ citation_text }}</p>
        <button class="c-button c-button--primary js-citation-copy" data-citation="{{ citation_text|striptags }}" aria-label="{{ 'Copy citation'|t }}">
          <svg class="citation-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
    {% endif %}
  {% endset %}

  {% set table_of_contents %}
    {% set dropdown_items %}
      {{ toc }}
    {% endset %}
    {{ include('jakarta:c-dropdown', {
      toggle: 'Table of contents'|t,
      dropdown_items,
    }, with_context = false) }}
  {% endset %}

  {% set related_items %}
    {% set extra_pers_inst_flds = [
      'field_date_start',
      'field_date_start_year_only',
      'field_date_end_year_only'
    ] %}

    {% for relfield in rn('relation_fields_list', node, bundle_order) %}
      {% set rel_data = rn('formatted_relations', node, relfield, {
        'language_fallback': true,
        'limit': limit,
        'extra_fields': {
          'computed_relationshipfield__person__institution': extra_pers_inst_flds,
          'computed_relationshipfield__institution__person': extra_pers_inst_flds,
        }
      }) %}
      {% if rel_data %}
        {% set bundle_config = bundles[rel_data.title] ?? null %}

        {# Bouw more URL op via route + filterparameter. #}
        {% set more_url = null %}
        {% if rel_data.has_more and bundle_config and bundle_config.more_route %}
          {% set more_url = path(bundle_config.more_route) ~ '?' ~ filter_key ~ '=' ~ filter_value %}
        {% endif %}

        {% set items %}
          <ul class="links">
            {% for rel in rel_data.items %}
              <li>
                <a href="{{ rel._is_fallback ? path('bestor_content_helper.translation_unavailable', {nid: rel._related_nid}) : rel.related_id.url }}"
                  class="relationship-link{{ rel._is_fallback ? ' relationship-link--unavailable' : '' }}">
                  {{ rel.related_id.value }}
                </a>
                {% if rel.relation_type_name %}({{ rel.relation_type_name.value }}){% endif %}
              </li>
            {% endfor %}
            {% if more_url %}
              <li class="more-link">
                <a href="{{ more_url }}">{{ 'Show all'|t }}</a>
              </li>
            {% endif %}
          </ul>
        {% endset %}

        {{ include('jakarta:c-related-items', {
          title: bundle_config ? bundle_config.label : rel_data.title,
          items,
        }, with_context = false) }}
      {% endif %}
    {% endfor %}
  {% endset %}

  {{ include('jakarta:c-lemma-sidebar', {
    buttons,
    table_of_contents,
    related_items,
  }, with_context = false) }}
{% endset %}

{{ include('jakarta:c-structured-layout', {
  top,
  content,
  sidebar
}, with_context = false) }}