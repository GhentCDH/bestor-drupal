<?php

/**
 * @file
 * Cytoscape Ego Network module.
 *
 * Adds a "Show ego network" boolean field to configured node bundles.
 * When the field is TRUE, the EgoNetworkFormatter renders an interactive
 * Cytoscape.js graph of directly related nodes and their mutual connections.
 */

use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Field\BaseFieldDefinition;

/**
 * Implements hook_entity_bundle_field_info().
 */
function cytoscape_egonetwork_entity_bundle_field_info(EntityTypeInterface $entity_type, string $bundle, array $base_field_definitions): array {
  if ($entity_type->id() !== 'node') {
    return [];
  }

  $enabledBundles = \Drupal::config('cytoscape_egonetwork.settings')->get('enabled_bundles') ?? [];
  if (!in_array($bundle, $enabledBundles, TRUE)) {
    return [];
  }

  $fields = [];
  $fields['show_ego_network'] = BaseFieldDefinition::create('boolean')
    ->setLabel(t('Show ego network'))
    ->setDescription(t('Display the interactive network graph on this node.'))
    ->setDefaultValue(FALSE)
    ->setDisplayOptions('form', [
      'type'     => 'boolean_checkbox',
      'weight'   => 100,
      'settings' => ['display_label' => TRUE],
    ])
    ->setDisplayOptions('view', [
      'type'   => 'cytoscape_egonetwork',
      'weight' => 100,
      'label'  => 'hidden',
    ])
    ->setDisplayConfigurable('form', TRUE)
    ->setDisplayConfigurable('view', TRUE)
    ->setRevisionable(TRUE)
    ->setTranslatable(FALSE);

  return $fields;
}