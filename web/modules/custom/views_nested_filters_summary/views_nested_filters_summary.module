<?php

use Drupal\Core\Url;
use Drupal\views\Plugin\views\filter\FilterPluginBase;
use Drupal\views\ViewExecutable;


/**
 * Implements hook_views_filters_summary_item_alter().
 *
 * Replaces href="/" on remove-filter links with href="#".
 * The contrib module generates Url::fromUserInput('/') as placeholder —
 * this prevents accidental navigation to the homepage if JS fails.
 */
function views_nested_filters_summary_views_filters_summary_item_alter(array &$item): void {
  if (isset($item['link']['#url'])) {
    $item['link']['#url'] = Url::fromUserInput('#');
  }
}


/**
 * Implements hook_views_pre_render().
 *
 * Populates $filter->value and exposed_input for facets_filter plugins so
 * views_filters_summary can pick them up.
 */
function views_nested_filters_summary_views_pre_render(ViewExecutable $view): void {
  \Drupal::service('views_nested_filters_summary.facets_resolver')
    ->populateFacetValues($view);
}


/**
 * Implements hook_views_filters_summary_info_alter().
 *
 * Builds summary labels for facets_filter plugins.
 */
function views_nested_filters_summary_views_filters_summary_info_alter(array &$info, FilterPluginBase $filter): void {
  \Drupal::service('views_nested_filters_summary.facets_resolver')
    ->buildSummaryInfo($info, $filter);
}


/**
 * Implements hook_page_attachments().
 */
function views_nested_filters_summary_page_attachments(array &$attachments): void {
  $attachments['#attached']['library'][] = 'views_nested_filters_summary/nested-filters-summary';
}